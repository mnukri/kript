generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum LaborCategory {
  FTE
  COOP
  TEMP

  @@map("labor_category")
}

enum ProgramStatus {
  active
  closed
  pending

  @@map("program_status")
}

enum ChargeType {
  effort
  purchase
  travel

  @@map("charge_type")
}

enum ChargeStatus {
  draft
  submitted
  approved
  rejected

  @@map("charge_status")
}

enum GlobalRole {
  admin
  manager
  staff

  @@map("global_role")
}

enum AccessLevel {
  read
  write
  approve

  @@map("access_level")
}

// ---------------------------------------------------------------------------
// Staff
// ---------------------------------------------------------------------------

model Staff {
  staff_id       Int            @id @default(autoincrement())
  first_name     String         @db.VarChar(100)
  last_name      String         @db.VarChar(100)
  email          String?        @unique @db.VarChar(255)
  job_title      String?        @db.VarChar(150)
  department     String?        @db.VarChar(150)
  labor_category LaborCategory
  hire_date      DateTime?      @db.Date
  is_active      Boolean        @default(true)
  manager_id     Int?
  created_at     DateTime       @default(now())

  manager        Staff?         @relation("StaffManager", fields: [manager_id], references: [staff_id])
  reports        Staff[]        @relation("StaffManager")
  salaries       StaffSalary[]
  effortEntries  EffortEntry[]
  charges        Charge[]       @relation("StaffCharges")
  approvals      Charge[]       @relation("ApprovedCharges")
  programsAsTpoc Program[]      @relation("TpocStaff")
  user           User?

  @@map("staff")
}

// ---------------------------------------------------------------------------
// Fringe rates
// ---------------------------------------------------------------------------

model FringeRate {
  fringe_rate_id Int           @id @default(autoincrement())
  labor_category LaborCategory
  rate           Decimal        @db.Decimal(6, 4)
  effective_date DateTime       @db.Date
  end_date       DateTime?      @db.Date
  notes          String?

  @@unique([labor_category, effective_date])
  @@map("fringe_rates")
}

// ---------------------------------------------------------------------------
// Indirect rates
// ---------------------------------------------------------------------------

model IndirectRate {
  indirect_rate_id Int      @id @default(autoincrement())
  rate_type        String   @db.VarChar(100)
  rate             Decimal  @db.Decimal(6, 4)
  effective_date   DateTime @db.Date
  end_date         DateTime? @db.Date
  notes            String?

  @@unique([rate_type, effective_date])
  @@map("indirect_rates")
}

// ---------------------------------------------------------------------------
// Programs
// ---------------------------------------------------------------------------

model Program {
  program_id                                Int           @id @default(autoincrement())
  program_name                              String        @db.VarChar(255)
  worktag                                   String        @db.VarChar(100)
  status                                    ProgramStatus @default(active)
  pop_start                                 DateTime?     @db.Date
  pop_end                                   DateTime?     @db.Date
  total_budget_burdened                     Decimal?      @db.Decimal(15, 2)
  total_budget_salary_burdened              Decimal?      @db.Decimal(15, 2)
  total_budget_salary_unburdened            Decimal?      @db.Decimal(15, 2)
  total_budget_purchases_unburdened         Decimal?      @db.Decimal(15, 2)
  total_budget_capital_equipment_unburdened Decimal?      @db.Decimal(15, 2)
  sponsor                                   String?       @db.VarChar(255)
  grant_number                              String?       @db.VarChar(100)
  tpoc_staff_id                             Int?
  created_at                                DateTime      @default(now())

  tpoc          Staff?              @relation("TpocStaff", fields: [tpoc_staff_id], references: [staff_id])
  effortEntries EffortEntry[]
  charges       Charge[]
  permissions   ProgramPermission[]

  @@map("programs")
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------

model User {
  user_id       Int        @id @default(autoincrement())
  staff_id      Int        @unique
  email         String     @unique @db.VarChar(255)
  microsoft_oid String?    @unique @db.VarChar(255)
  global_role   GlobalRole @default(staff)
  created_at    DateTime   @default(now())

  staff       Staff               @relation(fields: [staff_id], references: [staff_id])
  permissions ProgramPermission[] @relation("UserPermissions")
  grants      ProgramPermission[] @relation("GrantedBy")

  @@map("users")
}

// ---------------------------------------------------------------------------
// Program permissions
// ---------------------------------------------------------------------------

model ProgramPermission {
  permission_id Int         @id @default(autoincrement())
  user_id       Int
  program_id    Int
  access_level  AccessLevel
  granted_by    Int

  user    User    @relation("UserPermissions", fields: [user_id],    references: [user_id])
  program Program @relation(fields: [program_id], references: [program_id])
  granter User    @relation("GrantedBy",       fields: [granted_by], references: [user_id])

  @@unique([user_id, program_id])
  @@map("program_permissions")
}

// ---------------------------------------------------------------------------
// Staff salaries
// ---------------------------------------------------------------------------

model StaffSalary {
  salary_id      Int       @id @default(autoincrement())
  staff_id       Int
  annual_salary  Decimal   @db.Decimal(15, 2)
  effective_date DateTime  @db.Date
  end_date       DateTime? @db.Date
  notes          String?

  staff Staff @relation(fields: [staff_id], references: [staff_id])

  @@unique([staff_id, effective_date])
  @@map("staff_salaries")
}

// ---------------------------------------------------------------------------
// Effort entries
// ---------------------------------------------------------------------------

model EffortEntry {
  effort_id   Int      @id @default(autoincrement())
  staff_id    Int
  program_id  Int
  effort_date DateTime @db.Date
  percentage  Decimal  @db.Decimal(5, 2)
  notes       String?
  created_at  DateTime @default(now())

  staff   Staff   @relation(fields: [staff_id], references: [staff_id])
  program Program @relation(fields: [program_id], references: [program_id])

  @@unique([staff_id, program_id, effort_date])
  @@map("effort_entries")
}

// ---------------------------------------------------------------------------
// Charges
// ---------------------------------------------------------------------------

model Charge {
  charge_id        Int          @id @default(autoincrement())
  program_id       Int
  staff_id         Int
  charge_type      ChargeType
  charge_date      DateTime     @db.Date
  amount           Decimal?     @db.Decimal(15, 2)
  description      String?
  reference_number Int          @default(1)
  status           ChargeStatus @default(draft)
  approved_by      Int?
  approved_at      DateTime?
  notes            String?
  created_at       DateTime     @default(now())

  program         Program               @relation(fields: [program_id], references: [program_id])
  staff           Staff                 @relation("StaffCharges",   fields: [staff_id],   references: [staff_id])
  approver        Staff?                @relation("ApprovedCharges", fields: [approved_by], references: [staff_id])
  travelDetails   ChargeTravelDetails?
  purchaseDetails ChargePurchaseDetails?

  @@unique([program_id, staff_id, charge_date, charge_type, reference_number])
  @@map("charges")
}

// ---------------------------------------------------------------------------
// Charge travel details
// ---------------------------------------------------------------------------

model ChargeTravelDetails {
  charge_id      Int      @id
  destination    String?  @db.VarChar(255)
  trip_purpose   String?
  departure_date DateTime @db.Date
  return_date    DateTime @db.Date

  charge Charge @relation(fields: [charge_id], references: [charge_id], onDelete: Cascade)

  @@map("charge_travel_details")
}

// ---------------------------------------------------------------------------
// Charge purchase details
// ---------------------------------------------------------------------------

model ChargePurchaseDetails {
  charge_id Int     @id
  vendor    String? @db.VarChar(255)
  category  String? @db.VarChar(100)

  charge Charge @relation(fields: [charge_id], references: [charge_id], onDelete: Cascade)

  @@map("charge_purchase_details")
}
